{
  "name": "home",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bunx --bun vite dev --port 5174",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "check": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "bunx prettier --check .",
    "format": "bunx prettier --write .",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "clean": "rm -rf .svelte-kit build node_modules/.vite"
  },
  "devDependencies": {
    "@budget/config": "workspace:*",
    "@lucide/svelte": "^0.562.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.55.3",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "@budget/core": "workspace:*",
    "@budget/ui": "workspace:*",
    "@internationalized/date": "^3.12.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tanstack/svelte-query": "^6.1.16",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "better-auth": "^1.6.2",
    "better-sqlite3": "^12.8.0",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.7",
    "mode-watcher": "^1.1.0",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "zod": "4.3.6"
  }
}
