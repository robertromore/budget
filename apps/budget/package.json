{
  "name": "budget",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bunx --bun vite dev",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "test": "bun run test:unit && bun run test:playwright",
    "test:unit": "bunx vitest run tests/unit/",
    "test:integration": "bun test tests/integration/import tests/integration/reports tests/integration/medical tests/integration/categories tests/integration/ml tests/integration/patterns tests/integration/annotations tests/integration/workspace tests/integration/auth tests/integration/onboarding tests/integration/budgets tests/integration/transactions tests/integration/payees tests/integration/utility tests/integration/connections tests/integration/ai tests/integration/aliases tests/integration/automation tests/integration/category-groups tests/integration/crud tests/integration/expenses tests/integration/filters tests/integration/payee-categories tests/integration/sequences tests/integration/transfers tests/integration/schedules tests/integration/schedules.test.ts tests/integration/payee-routes.test.ts tests/integration/intelligence-routes.test.ts tests/integration/setup",
    "test:e2e": "bunx vitest run tests/e2e/",
    "test:coverage": "bunx vitest run --coverage",
    "test:watch": "bunx vitest watch",
    "test:ui": "bunx vitest --ui",
    "test:bun": "bun test tests/integration/trpc tests/integration/validation tests/integration/security tests/unit/balance-calculation.test.ts tests/unit/components tests/unit/filters tests/unit/trpc tests/unit/utils && bunx vitest run tests/unit/states/accounts-sorting.test.ts",
    "test:bun:watch": "bun test --watch tests/integration/trpc tests/integration/validation tests/integration/security tests/unit/balance-calculation.test.ts tests/unit/components tests/unit/filters tests/unit/trpc tests/unit/utils",
    "test:playwright": "npx playwright test",
    "test:playwright:ui": "bunx playwright test --ui",
    "test:playwright:debug": "bunx playwright test --debug",
    "check": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "bunx prettier --check .",
    "format": "bunx prettier --write .",
    "dev:check": "./scripts/dev-check.sh",
    "dev:setup": "./scripts/setup-dev.sh",
    "generate:component": "./scripts/component-generator.sh",
    "generate:widget": "node ./scripts/generate-widget.js",
    "generate:chart": "node ./scripts/generate-chart.js",
    "analyze": "./scripts/analyze-bundle.sh",
    "perf:monitor": "./scripts/performance-monitor.sh",
    "db:generate": "bunx drizzle-kit generate",
    "db:baseline": "./scripts/baseline-drizzle-migrations.sh",
    "db:migrate": "bun run db:baseline && bunx drizzle-kit migrate",
    "db:seed": "bun run ./src/lib/server/db/seeders",
    "db:reseed": "bun run ./src/lib/server/db/delete-all && bun run ./src/lib/server/db/seeders",
    "db:factory": "bun run ./src/lib/server/db/factories",
    "db:refactory": "bun run ./src/lib/server/db/delete-all && bun run ./src/lib/server/db/factories",
    "db:drop": "rm -rf ./drizzle/meta ./drizzle/*.sql ./drizzle/db/sqlite.db",
    "db:restart": "bun run db:drop && bun run db:generate && bun run db:migrate && bun run db:seed",
    "db:restart:test": "bun run db:drop && bun run db:generate && bun run db:migrate && bun run db:seed && bun run db:factory",
    "db:fresh": "bun run db:drop && bun run db:generate && bun run db:migrate",
    "cache:help": "./scripts/context7-cache-help.sh",
    "cache:status": "ls -la ../../.context7-cache/",
    "cache:clean": "rm -rf ../../.context7-cache && echo 'Context7 cache cleared'",
    "clean": "rm -rf .svelte-kit build node_modules/.vite"
  },
  "devDependencies": {
    "@budget/config": "workspace:*",
    "@faker-js/faker": "^10.4.0",
    "@lucide/svelte": "^0.562.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte-inspector": "^5.0.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.11",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/validator": "^13.15.10",
    "@typeschema/class-validator": "^0.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "bun-types": "^1.3.11",
    "class-validator": "^0.14.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-svelte": "^3.16.0",
    "postcss": "^8.5.8",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.55.0",
    "svelte-adapter-bun": "^1.0.1",
    "svelte-check": "^4.4.5",
    "svelte-render-scan": "^1.1.0",
    "tailwindcss": "^4.2.2",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48",
    "@ai-sdk/svelte": "^4.0.141",
    "@budget/core": "workspace:*",
    "@budget/ui": "workspace:*",
    "@decs/typeschema": "^0.12.2",
    "@dnd-kit-svelte/core": "^0.0.11",
    "@dnd-kit-svelte/modifiers": "^0.0.11",
    "@dnd-kit-svelte/sortable": "^0.0.11",
    "@dnd-kit-svelte/utilities": "^0.0.11",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@humanspeak/svelte-virtual-list": "^0.3.13",
    "@internationalized/date": "^3.12.0",
    "@libsql/client": "^0.15.15",
    "@paralleldrive/cuid2": "^3.3.0",
    "@shikijs/langs": "^3.23.0",
    "@shikijs/themes": "^3.23.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/svelte-query": "^6.1.10",
    "@tanstack/svelte-table": "^8.21.3",
    "@tanstack/table-core": "^8.21.3",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@xyflow/svelte": "^1.5.2",
    "ai": "^6.0.141",
    "ai-sdk-ollama": "^3.8.2",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "better-sqlite3": "^12.8.0",
    "bits-ui": "^2.16.4",
    "caniuse-lite": "^1.0.30001781",
    "clsx": "^2.1.1",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "drizzle-orm": "^0.44.7",
    "drizzle-valibot": "^0.4.2",
    "drizzle-zod": "^0.8.3",
    "fast-xml-parser": "^5.5.9",
    "fastest-levenshtein": "^1.0.16",
    "formsnap": "^2.0.1",
    "fuse.js": "^7.1.0",
    "html2pdf.js": "^0.12.1",
    "isomorphic-dompurify": "^2.36.0",
    "layercake": "^10.0.2",
    "marked": "^17.0.5",
    "minimatch": "^10.2.4",
    "ml-distance": "^4.0.1",
    "ml-regression": "^6.3.0",
    "mode-watcher": "^1.1.0",
    "nuqs-svelte": "^1.2.2",
    "ollama": "^0.6.3",
    "paneforge": "^1.0.2",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "resend": "^6.9.4",
    "runed": "^0.37.1",
    "shadcn-svelte": "^1.2.4",
    "shiki": "^3.23.0",
    "simple-statistics": "^7.8.9",
    "svelte-dnd-action": "^0.9.69",
    "svelte-sonner": "^1.1.0",
    "svelte-streamdown": "^3.0.1",
