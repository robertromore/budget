{
  "name": "@budget/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Budget desktop app powered by Electrobun",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5174",
    "build:canary": "vite build && electrobun build --env=canary"
  },
  "dependencies": {
    "@budget/core": "workspace:*",
    "@budget/ui": "workspace:*",
    "@lucide/svelte": "^0.526.0",
    "@tanstack/svelte-query": "^6.1.24",
    "@trpc/client": "^11.16.0",
    "bits-ui": "2.15.5",
    "clsx": "^2.1.1",
    "electrobun": "1.16.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/bun": "latest",
    "concurrently": "^9.2.1",
    "svelte": "^5.55.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  }
}
